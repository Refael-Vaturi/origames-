name: Build iOS IPA

on:
  push:
    branches: [ main, master ] # מפעיל את הבנייה בכל פעם שאתה מעדכן את הקוד
  workflow_dispatch: # מאפשר לך להפעיל את הבנייה גם ידנית בלחיצת כפתור

jobs:
  build-ios:
    runs-on: macos-latest # כאן קורה הקסם - GitHub מפעיל מחשב מק בענן!

    steps:
    - name: Checkout Source Code
      uses: actions/checkout@v4

    - name: Setup Node.js
      uses: actions/setup-node@v4
      with:
        node-size: 20

    - name: Install Dependencies
      run: npm install

    - name: Build Web Project
      run: npm run build

    - name: Install Capacitor iOS
      run: |
        npm install @capacitor/ios
        npx cap sync ios

    - name: Build Xcode Project (Simulator / Unsigned IPA)
      run: |
        cd ios/App
        xcodebuild -workspace App.xcworkspace -scheme App -sdk iphoneos -configuration Release CODE_SIGNING_ALLOWED=NO -archivePath $PWD/build/App.xcarchive archive
        mkdir -p $GITHUB_WORKSPACE/build
        xcrun xcodebuild -exportArchive -archivePath $PWD/build/App.xcarchive -exportPath $GITHUB_WORKSPACE/build -exportOptionsPlst <(echo '<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd"><plist version="1.0"><dict><key>method</key><string>ad-hoc</string><key>compileBitcode</key><false/></dict></plist>')

    - name: Upload Finished IPA
      uses: actions/upload-artifact@v4
      with:
        name: ios-app-ipa
        path: build/*.ipa
